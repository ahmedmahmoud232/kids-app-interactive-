rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (Firebase Auth UID)
    // Fields:
    //   - currentChildId: string (optional)
    //   - children: list of maps
    //     - id: string
    //     - name: string (1-50 chars)
    //     - age: number (4-13)
    //     - level: number (>=1)
    //     - points: number (>=0)
    //     - progress: map
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == "ahmedmahmoud22990@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['children']) &&
             data.children is list &&
             data.children.size() <= 10 && // Limit to 10 children
             (!('currentChildId' in data) || data.currentChildId is string);
    }

    function isValidGame(data) {
      return data.keys().hasAll(['id', 'title', 'description', 'category', 'minAge', 'maxAge', 'color', 'icon']) &&
             data.title is string && data.title.size() <= 100 &&
             data.category in ['math', 'language', 'science', 'logic'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
      allow delete: if isOwner(userId);
    }

    match /games/{gameId} {
      // Everyone can read games
      allow read: if true;
      // Only admin can manage games
      allow write: if isAdmin() && isValidGame(request.resource.data);
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
