{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User account containing multiple children profiles",
      "type": "object",
      "properties": {
        "currentChildId": { "type": "string" },
        "children": {
          "type": "array",
          "items": { "$ref": "#/entities/ChildProfile" }
        }
      },
      "required": ["children"]
    },
    "ChildProfile": {
      "title": "ChildProfile",
      "description": "Individual child profile data",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "age": { "type": "number" },
        "level": { "type": "number" },
        "points": { "type": "number" },
        "progress": { "type": "object" }
      },
      "required": ["id", "name", "age", "level", "points"]
    },
    "Game": {
      "title": "Game",
      "description": "Educational game metadata",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string", "enum": ["math", "language", "science", "logic"] },
        "minAge": { "type": "number" },
        "maxAge": { "type": "number" },
        "color": { "type": "string" },
        "icon": { "type": "string" }
      },
      "required": ["id", "title", "description", "category", "minAge", "maxAge", "color", "icon"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Root user document containing all children data"
    },
    "/games/{gameId}": {
      "schema": "Game",
      "description": "Global games library"
    }
  }
}
